{
  "name": "hayai-db",
  "version": "0.8.0",
  "type": "module",
  "description": "⚡ Instantly create and manage local databases with one command",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "hayai": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "HAYAIDB.md",
    "ABOUT_BACKUP.md",
    "AUTOMATION.md",
    "CONTRIBUTING.md",
    "DEVELOPMENT.md",
    ".hayaidb",
    "hayai.config.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/cli/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=\"src/tests/unit\" --verbose",
    "test:integration": "npm run build && jest --config jest.integration.config.cjs --verbose",
    "test:cli": "jest --testPathPatterns=\"src/tests/cli\" --verbose --testTimeout=120000",
    "test:database": "jest --testPathPatterns=\"src/tests/database-specific\" --verbose --testTimeout=180000",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:cli && npm run test:database",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepack": "npm run build"
  },
  "keywords": [
    "database",
    "docker",
    "cli",
    "sql",
    "keyvalue",
    "widecolumn",
    "timeseries",
    "vector",
    "backend",
    "development",
    "mariadb",
    "postgresql",
    "redis",
    "cassandra",
    "qdrant",
    "meilisearch",
    "sqlite",
    "duckdb",
    "influxdb2",
    "influxdb3",
    "timescaledb",
    "questdb"
  ],
  "author": "hitoshyamamoto <andrehitoshi.01@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hitoshyamamoto/hayai.git"
  },
  "bugs": {
    "url": "https://github.com/hitoshyamamoto/hayai/issues"
  },
  "homepage": "https://github.com/hitoshyamamoto/hayai#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "ora": "^9.4.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "~5.9",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
